{
  "name": "viewgallery",
  "version": "0.1.3",
  "description": "A fast, cross-platform media gallery viewer.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:mac": "tauri build --target universal-apple-darwin",
    "build:mac:arm": "tauri build --target aarch64-apple-darwin",
    "build:mac:intel": "tauri build --target x86_64-apple-darwin",
    "build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "dev:mac": "tauri dev",
    "dev:mac:arm": "tauri dev --target aarch64-apple-darwin",
    "dev:mac:intel": "tauri dev --target x86_64-apple-darwin",
    "dev:windows": "tauri dev --target x86_64-pc-windows-msvc",
    "dev:linux": "tauri dev --target x86_64-unknown-linux-gnu",
    "version": "node scripts/sync-version.mjs && git add src-tauri/tauri.conf.json src-tauri/Cargo.toml",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
