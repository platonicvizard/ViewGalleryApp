{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ViewGallery",
  "version": "0.1.0",
  "identifier": "com.sundrygroup.viewgallery",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "ViewGallery",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "jpg",
          "jpeg",
          "png",
          "gif",
          "webp",
          "bmp",
          "tiff",
          "tif",
          "avif",
          "heic",
          "heif",
          "svg",
          "mp4",
          "mov",
          "webm",
          "mkv",
          "avi",
          "m4v",
          "wmv",
          "flv",
          "mpg",
          "mpeg"
        ],
        "name": "Media File",
        "description": "Image or video viewable in ViewGallery",
        "role": "Viewer"
      }
    ]
  }
}
